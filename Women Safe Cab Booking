import java.util.*;

class Ride{
    String passenger;
    String pickup;
    String drop;
    int fare;
    int otp;
    String status;

    Ride(String passenger,String pickup,String drop,int fare,int otp){
        this.passenger=passenger;
        this.pickup=pickup;
        this.drop=drop;
        this.fare=fare;
        this.otp=otp;
        this.status="BOOKED";
    }
}

class DriverJob{
    String name;
    String phone;
    String vehicle;
    int exp;

    DriverJob(String name,String phone,String vehicle,int exp){
        this.name=name;
        this.phone=phone;
        this.vehicle=vehicle;
        this.exp=exp;
    }
}

class Feedback{
    String name;
    String rating;
    String comment;

    Feedback(String name,String rating,String comment){
        this.name=name;
        this.rating=rating;
        this.comment=comment;
    }
}

class Contact{
    String name;
    String phone;

    Contact(String name,String phone){
        this.name=name;
        this.phone=phone;
    }
}

public class WomenSafeCabSystem {

    static Scanner sc=new Scanner(System.in);

    // Login system
    static HashMap<String,String> passengers=new HashMap<>();
    static HashMap<String,String> drivers=new HashMap<>();

    // Ride management
    static Queue<Ride> rideQueue=new LinkedList<>();
    static Stack<Ride> rideHistory=new Stack<>();

    // Other storage
    static ArrayList<DriverJob> jobs=new ArrayList<>();
    static ArrayList<Feedback> feedbacks=new ArrayList<>();
    static ArrayList<Contact> contacts=new ArrayList<>();

    static Ride currentRide=null;
    static Ride passengerRide=null;

    public static void main(String[] args){

        while(true){

            System.out.println("\n=== WOMEN SAFE CAB BOOKING SYSTEM ===");
            System.out.println("1 Register");
            System.out.println("2 Login");
            System.out.println("3 Exit");

            int choice=sc.nextInt();

            switch(choice){
                case 1: register(); break;
                case 2: login(); break;
                case 3: System.exit(0);
            }
        }
    }

    static void register(){

        System.out.println("Register as:");
        System.out.println("1 Passenger");
        System.out.println("2 Driver");

        int type=sc.nextInt();
        sc.nextLine();

        System.out.print("Username: ");
        String user=sc.nextLine();

        System.out.print("Password: ");
        String pass=sc.nextLine();

        if(type==1)
            passengers.put(user,pass);
        else
            drivers.put(user,pass);

        System.out.println("Registration Successful");
    }

    static void login(){

        System.out.println("Login as:");
        System.out.println("1 Passenger");
        System.out.println("2 Driver");

        int type=sc.nextInt();
        sc.nextLine();

        System.out.print("Username: ");
        String user=sc.nextLine();

        System.out.print("Password: ");
        String pass=sc.nextLine();

        if(type==1 && passengers.containsKey(user) && passengers.get(user).equals(pass))
            passengerMenu();

        else if(type==2 && drivers.containsKey(user) && drivers.get(user).equals(pass))
            driverMenu();

        else
            System.out.println("Invalid Login");
    }

    static void passengerMenu(){

        while(true){

            System.out.println("\nPassenger Menu");
            System.out.println("1 Book Ride");
            System.out.println("2 View Ride Status");
            System.out.println("3 Cancel Ride");
            System.out.println("4 Give Feedback");
            System.out.println("5 Apply Driving Job");
            System.out.println("6 Emergency Contacts");
            System.out.println("7 SOS Alert");
            System.out.println("8 Logout");

            int ch=sc.nextInt();

            switch(ch){
                case 1: bookRide(); break;
                case 2: rideStatus(); break;
                case 3: cancelRide(); break;
                case 4: submitFeedback(); break;
                case 5: applyDriverJob(); break;
                case 6: addContact(); break;
                case 7: sendSOS(); break;
                case 8: return;
            }
        }
    }

    static void driverMenu(){

        while(true){

            System.out.println("\nDriver Panel");
            System.out.println("Pending Requests: "+rideQueue.size());
            System.out.println("1 View Ride Requests");
            System.out.println("2 Accept Ride");
            System.out.println("3 Reject Ride");
            System.out.println("4 Verify OTP");
            System.out.println("5 Complete Ride");
            System.out.println("6 Ride History");
            System.out.println("7 View Driver Applications");
            System.out.println("8 Logout");

            int ch=sc.nextInt();

            switch(ch){
                case 1: showRideRequests(); break;
                case 2: acceptRide(); break;
                case 3: rejectRide(); break;
                case 4: verifyOTP(); break;
                case 5: completeRide(); break;
                case 6: showRideHistory(); break;
                case 7: viewDriverApplications(); break;
                case 8: return;
            }
        }
    }

    static int calculateFare(int distance){
        return 50 + (distance*15);
    }

    static void bookRide(){

        sc.nextLine();

        System.out.print("Passenger Name: ");
        String name=sc.nextLine();

        System.out.print("Pickup: ");
        String pickup=sc.nextLine();

        System.out.print("Drop: ");
        String drop=sc.nextLine();

        int distance=new Random().nextInt(10)+1;
        int fare=calculateFare(distance);
        int otp=1000+new Random().nextInt(9000);

        Ride ride=new Ride(name,pickup,drop,fare,otp);

        rideQueue.add(ride);
        passengerRide=ride;

        System.out.println("Ride Booked Successfully");
        System.out.println("Distance: "+distance+" km");
        System.out.println("Fare: "+fare);
        System.out.println("OTP: "+otp);
    }

    static void rideStatus(){

        if(passengerRide==null)
            System.out.println("No ride booked");

        else{
            System.out.println("Passenger: "+passengerRide.passenger);
            System.out.println("Route: "+passengerRide.pickup+" -> "+passengerRide.drop);
            System.out.println("Status: "+passengerRide.status);
        }
    }

    static void cancelRide(){

        if(passengerRide==null){
            System.out.println("No ride to cancel");
            return;
        }

        rideQueue.remove(passengerRide);
        passengerRide=null;

        System.out.println("Ride Cancelled");
    }

    static void showRideRequests(){

        if(rideQueue.isEmpty()){
            System.out.println("No Ride Requests");
            return;
        }

        for(Ride r:rideQueue){
            System.out.println(r.passenger+" | "+r.pickup+" -> "+r.drop+" | Fare:"+r.fare);
        }
    }

    static void acceptRide(){

        if(rideQueue.isEmpty()){
            System.out.println("No rides");
            return;
        }

        currentRide=rideQueue.poll();
        currentRide.status="DRIVER ASSIGNED";

        System.out.println("Ride Accepted for "+currentRide.passenger);
    }

    static void rejectRide(){

        if(rideQueue.isEmpty()){
            System.out.println("No ride requests");
            return;
        }

        Ride r=rideQueue.poll();
        System.out.println("Ride Rejected: "+r.passenger);
    }

    static void verifyOTP(){

        if(currentRide==null){
            System.out.println("No ride");
            return;
        }

        System.out.print("Enter OTP: ");
        int entered=sc.nextInt();

        if(entered==currentRide.otp){
            currentRide.status="RIDE STARTED";
            System.out.println("Ride Started");
        }else{
            System.out.println("Wrong OTP");
        }
    }

    static void completeRide(){

        if(currentRide==null){
            System.out.println("No ride to complete");
            return;
        }

        currentRide.status="COMPLETED";
        rideHistory.push(currentRide);

        passengerRide=null;
        currentRide=null;

        System.out.println("Ride Completed");
    }

    static void showRideHistory(){

        if(rideHistory.isEmpty()){
            System.out.println("No history");
            return;
        }

        for(Ride r:rideHistory)
            System.out.println(r.passenger+" "+r.pickup+" -> "+r.drop+" | "+r.status);
    }

    static void applyDriverJob(){

        sc.nextLine();

        System.out.print("Name: ");
        String name=sc.nextLine();

        System.out.print("Phone: ");
        String phone=sc.nextLine();

        System.out.print("Vehicle: ");
        String vehicle=sc.nextLine();

        System.out.print("Experience: ");
        int exp=sc.nextInt();

        jobs.add(new DriverJob(name,phone,vehicle,exp));

        System.out.println("Application Submitted");
    }

    static void viewDriverApplications(){

        if(jobs.isEmpty()){
            System.out.println("No applications");
            return;
        }

        for(DriverJob j:jobs)
            System.out.println(j.name+" | "+j.vehicle+" | "+j.exp+" yrs");
    }

    static void submitFeedback(){

        sc.nextLine();

        System.out.print("Name: ");
        String name=sc.nextLine();

        System.out.print("Rating: ");
        String rating=sc.nextLine();

        System.out.print("Comment: ");
        String comment=sc.nextLine();

        feedbacks.add(new Feedback(name,rating,comment));

        System.out.println("Feedback Submitted");
    }

    static void addContact(){

        sc.nextLine();

        System.out.print("Contact Name: ");
        String name=sc.nextLine();

        System.out.print("Phone: ");
        String phone=sc.nextLine();

        contacts.add(new Contact(name,phone));

        System.out.println("Contact Added");
    }

    static void sendSOS(){

        if(contacts.isEmpty()){
            System.out.println("No emergency contacts");
            return;
        }

        System.out.println("SOS ALERT SENT");

        for(Contact c:contacts)
            System.out.println("Alert sent to "+c.name+" : "+c.phone);
    }
}
